{
  "name": "isw-technosys",
  "private": true,
  "version": "1.0.0",
  "description": "ISW Technosys - Système Intégré de Ressources Humaines",
  "author": "ISW Technosys SARL",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env ELECTRON=true NODE_ENV=development electron .\"",
    "electron:build": "cross-env ELECTRON=true npm run build && electron-builder --win --mac",
    "electron:build:win": "cross-env ELECTRON=true npm run build && electron-builder --win",
    "electron:build:mac": "cross-env ELECTRON=true npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.isw.sirh",
    "productName": "ISW-SIRH",
    "directories": {
      "output": "C:/Users/Claus/Desktop/ISW-SIRH-Build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dir"
      ],
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "autoprefixer": "^10.5.2",
    "exceljs": "^4.4.0",
    "firebase": "^12.15.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.22.0",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
